# Copy this file to `.env` (in the same docker/ folder) and adjust as needed.
# `docker compose` automatically loads `.env` from the compose file's directory.

# --- Postgres ---
POSTGRES_DB=noname
POSTGRES_USER=noname
POSTGRES_PASSWORD=noname
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Adminer (DB GUI at http://localhost:$ADMINER_PORT) ---
ADMINER_PORT=8080

# --- App ports ---
BACKEND_PORT=8000
FRONTEND_PORT=5173
