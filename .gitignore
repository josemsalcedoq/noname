# --- Env files (local copies, never committed; .env.example holds the template) ---
.env
.env.local
.env.*.local

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Node / Vite ---
node_modules/
dist/
build/
.vite/

# --- App data (large or runtime-generated) ---
backend/models/
backend/tmp/
**/downloads/
downloads/

# --- Media files anywhere (yt-dlp / transcribe outputs) ---
*.mp4
*.webm
*.m4a
*.mp3
*.mkv
*.mov
*.flac
*.aac
*.opus
*.ogg
!frontend/public/**
!**/test-fixtures/**

# --- OS / IDE ---
.DS_Store
.idea/
.vscode/
*.swp

# --- Playwright ---
playwright/test-results/
playwright/playwright-report/
playwright/blob-report/
playwright/.playwright/

# --- Logs ---
*.log
