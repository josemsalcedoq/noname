# --- Env files (local copies, never committed; .env.example holds the template) ---
.env
.env.local
.env.*.local

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Node / Vite ---
node_modules/
dist/
build/
.vite/

# --- App data (large or runtime-generated) ---
backend/models/
backend/tmp/
backend/downloads/

# --- OS / IDE ---
.DS_Store
.idea/
.vscode/
*.swp

# --- Logs ---
*.log
